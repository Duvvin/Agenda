<%- include('includes/header') %>

<div class="login-container">
    <div class="login-card">
        <h1>Verificar E-mail</h1>

        <%- include('includes/flash_msg') %>

        <p
            style="
                text-align: center;
                margin-bottom: 20px;
                color: #4b5563;
            "
        >
            Digite o código enviado para seu e-mail para concluir o cadastro.
        </p>

        <form action="/verify-email" method="POST">

            <div class="input-group">
                <label for="codigo">Código de Verificação</label>
                <input
                    type="text"
                    id="codigo"
                    name="codigo"
                    placeholder="Digite o código recebido"
                    maxlength="6"
                    required
                >
            </div>

            <button type="submit" class="btn-submit">
                Verificar Código
            </button>
        </form>

        <p class="register-text">
            Não recebeu o código?
            <a id="resendLink" href="/register/resend-code">
                Reenviar código
            </a>
        </p>
    </div>
</div>

<script>
    const link = document.getElementById('resendLink');

    let remaining = Number("<%= remaining %>");

    if (remaining > 0) {

        link.style.pointerEvents = 'none';
        link.style.opacity = '0.5';

        const updateTimer = () => {
            link.textContent = `Reenviar código (${remaining}s)`;
        };

        updateTimer();

        const interval = setInterval(() => {

            remaining--;

            updateTimer();

            if (remaining <= 0) {
                clearInterval(interval);

                link.style.pointerEvents = 'auto';
                link.style.opacity = '1';
                link.textContent = 'Reenviar código';
            }

        }, 1000);
    }
</script>

<%- include('includes/footer') %>