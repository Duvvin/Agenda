<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Verificação de E-mail</title>
</head>

<body style="margin:0;padding:0;background-color:#f4f7fb;font-family:Arial,Helvetica,sans-serif;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="padding:40px 20px;">
    <tr>
        <td align="center">

            <table role="presentation" width="600" cellpadding="0" cellspacing="0"
                style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,.08);">

                <!-- Cabeçalho -->
                <tr>
                    <td align="center"
                        style="background:#2563eb;padding:35px 20px;color:#ffffff;">

                        <h1 style="margin:0;font-size:32px;font-weight:700;">
                            Agenda
                        </h1>

                        <p style="margin-top:10px;font-size:16px;">
                            Confirmação de cadastro
                        </p>

                    </td>
                </tr>

                <!-- Conteúdo -->
                <tr>
                    <td style="padding:40px 35px;color:#333333;">

                        <h2 style="margin-top:0;">
                            Olá, <%= name %>!
                        </h2>

                        <p style="font-size:16px;line-height:28px;">
                            Obrigado por criar sua conta na <strong>Agenda</strong>.
                        </p>

                        <p style="font-size:16px;line-height:28px;">
                            Para concluir seu cadastro, utilize o código abaixo na página de verificação:
                        </p>

                        <!-- Código -->
                        <table align="center" cellpadding="0" cellspacing="0"
                            style="margin:35px auto;">

                            <tr>
                                <td
                                    style="
                                    background:#eef4ff;
                                    border:2px dashed #2563eb;
                                    border-radius:10px;
                                    padding:18px 40px;
                                    font-size:38px;
                                    font-weight:bold;
                                    letter-spacing:8px;
                                    color:#2563eb;
                                    text-align:center;
                                    ">

                                    <%= code %>

                                </td>
                            </tr>

                        </table>

                        <p style="font-size:15px;color:#555;line-height:26px;">
                            Este código é válido por <strong>10 minutos</strong>.
                        </p>

                        <p style="font-size:15px;color:#555;line-height:26px;">
                            Caso você não tenha solicitado este cadastro, basta ignorar este e-mail.
                        </p>

                    </td>
                </tr>

                <!-- Rodapé -->
                <tr>
                    <td
                        align="center"
                        style="background:#f8f9fb;padding:25px;color:#888;font-size:13px;line-height:22px;">

                        Este é um e-mail automático. Não responda esta mensagem.
                        <br><br>

                        © <%= new Date().getFullYear() %> Agenda. Todos os direitos reservados.

                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>

</body>
</html>