<% if (error_msg && error_msg.length > 0) { %>
    <div class="error-box">
        <% error_msg.forEach(msg => { %>
            <p><%= msg %></p>
        <% }) %>
    </div>
<% } %>

<% if (success_msg && success_msg.length > 0) { %>
    <div class="success-box">
        <% success_msg.forEach(msg => { %>
            <p><%= msg %></p>
        <% }) %>
    </div>
<% } %>

<% if (error && error.length > 0) { %>
    <div class="error-box">
        <% error_msg.forEach(msg => { %>
            <p><%= msg %></p>
        <% }) %>
    </div>
<% } %>