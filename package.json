{
  "name": "Agenda",
  "version": "1.0.0",
  "description": "Agenda básica de contatos, projeto para treino de CRUD",
  "main": "src/server/server.js",
  "scripts": {
    "start": "node server.js --ignore public",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon src/server/server.js",
    "dev:client": "webpack serve --mode development",
    "build": "npx webpack --mode production",
    "build:watch": "npx webpack --mode development --watch"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "webpack"
  ],
  "author": "Vinicius Duarte",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-flash": "^0.1.1",
    "connect-mongo": "^4.4.0",
    "core-js": "^3.9.1",
    "cors": "^2.8.5",
    "css-loader": "^5.1.3",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.6",
    "express": "^4.21.2",
    "express-flash": "^0.0.2",
    "express-session": "^1.17.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.3",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.1",
    "regenerator-runtime": "^0.13.7",
    "style-loader": "^2.0.0",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "babel-loader": "^9.2.1",
    "concurrently": "^9.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.9.2",
    "nodemon": "^3.1.14",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs"
}
